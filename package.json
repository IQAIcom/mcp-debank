{
	"name": "@iqai/mcp-debank",
	"version": "2.1.0",
	"description": "Standalone MCP server for DeBank data access",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"mcp-debank": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build:docs": "tsx scripts/build-docs-index.ts",
		"build:instructions": "tsx scripts/build-instructions.ts",
		"prebuild": "pnpm run build:docs && pnpm run build:instructions",
		"build": "tsc && shx chmod +x dist/index.js",
		"pretest": "pnpm run build",
		"test": "cross-env NODE_OPTIONS=--no-node-snapshot vitest run",
		"test:watch": "cross-env NODE_OPTIONS=--no-node-snapshot vitest",
		"prepare": "husky && pnpm run build",
		"watch": "tsc --watch",
		"start": "node --no-node-snapshot dist/index.js",
		"format": "biome format . --write",
		"lint": "biome check .",
		"publish-packages": "pnpm run build && changeset publish"
	},
	"keywords": [
		"mcp",
		"debank",
		"defi"
	],
	"author": "IQAI",
	"license": "ISC",
	"dependencies": {
		"@iqai/adk": "^0.3.6",
		"axios": "^1.12.2",
		"dedent": "^1.7.0",
		"dotenv": "^17.2.3",
		"fastmcp": "^3.16.0",
		"jqts": "^0.0.8",
		"minisearch": "^7.2.0",
		"winston": "^3.18.3",
		"zod": "^4.1.11"
	},
	"optionalDependencies": {
		"isolated-vm": "^6.1.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.6",
		"@changesets/cli": "^2.29.4",
		"@types/node": "^24.6.2",
		"@vitest/coverage-v8": "^4.1.6",
		"cross-env": "^10.1.0",
		"husky": "^9.0.0",
		"lint-staged": "^15.0.0",
		"msw": "^2.14.6",
		"shx": "^0.3.4",
		"tsx": "^4.21.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.6"
	},
	"engines": {
		"node": ">=22"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"isolated-vm",
			"msw"
		]
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write --no-errors-on-unmatched"
		]
	},
	"homepage": "https://github.com/IQOfficial/mcp-debank#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/IQOfficial/mcp-debank.git"
	},
	"bugs": {
		"url": "https://github.com/IQOfficial/mcp-debank/issues"
	}
}
